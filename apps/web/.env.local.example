# Neon Database — for local development
# On Netlify, the NETLIFY_DATABASE_URL env var is injected automatically
# by the Neon integration. For local dev, copy this file to .env.local
# and set your Neon connection string below.
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/nexta?sslmode=require
